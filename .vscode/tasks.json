{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Start API",
      "type": "shell",
      "command": "cd backend && ./.venv/bin/python -m uvicorn app.main:app --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev-servers",
        "label": "Backend :8000"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^ERROR.*$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Uvicorn running on",
          "endsPattern": "Application startup complete"
        }
      },
      "runOptions": {
        "runOn": "default"
      }
    },
    {
      "label": "Frontend: Start Dev Server",
      "type": "shell",
      "command": "cd frontend && PORT=3000 npm run dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev-servers",
        "label": "Frontend :3000"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*error.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "▲ Next\\.js",
          "endsPattern": "Ready in"
        }
      }
    },
    {
      "label": "Dev: Start All",
      "dependsOn": ["Backend: Start API", "Frontend: Start Dev Server"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
